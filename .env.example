# Przykładowy plik .env
# Skopiuj ten plik jako .env i uzupełnij danymi

# Domain Configuration
DOMAIN=https://twoja-domena.pl

# Redis Cache (Optional - for better performance)
# Get free Redis from Railway, Redis Cloud, or Upstash
# REDIS_URL=redis://default:password@hostname:port

# PayPal Configuration
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# Email Configuration (opcjonalne - dla automatycznej wysyłki)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=twoj@email.com
# SMTP_PASSWORD=twoje_haslo

# Application Settings
# DEBUG=False
# HOST=0.0.0.0
# PORT=8000
